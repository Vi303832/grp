rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Yardımcı fonksiyonlar ───────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Custom claim ile rol kontrolü
    function hasRole(role) {
      return isAuth() && request.auth.token.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isBusiness() {
      return hasRole('business') || isAdmin();
    }

    // ─── users ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Kullanıcı kendi profilini okuyabilir, admin herkesi okuyabilir
      allow read: if isOwner(userId) || isAdmin();

      // Yeni profil yalnızca kayıt sırasında oluşturulabilir (kendi uid'i ile)
      allow create: if isOwner(userId)
        && request.resource.data.role == 'user'
        && request.resource.data.email == request.auth.token.email;

      // Hassas alanlar (role, email) güncellenemez; geri kalanı güncellenebilir
      allow update: if isOwner(userId)
        && !('role' in request.resource.data.diff(resource.data).affectedKeys())
        && !('email' in request.resource.data.diff(resource.data).affectedKeys());

      allow delete: if false;
    }

    // ─── cities ──────────────────────────────────────────────────────────────
    match /cities/{cityId} {
      allow read: if true;          // Herkes okuyabilir
      allow write: if isAdmin();
    }

    // ─── categories ──────────────────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── businesses ──────────────────────────────────────────────────────────
    match /businesses/{businessId} {
      allow read: if true;

      // İşletme sahibi kendi belgesini güncelleyebilir
      allow update: if isBusiness()
        && resource.data.ownerId == request.auth.uid
        && !('ownerId' in request.resource.data.diff(resource.data).affectedKeys())
        && !('isActive' in request.resource.data.diff(resource.data).affectedKeys());

      allow create, delete: if isAdmin();
    }

    // ─── campaigns ───────────────────────────────────────────────────────────
    match /campaigns/{campaignId} {
      // Aktif kampanyalar herkes tarafından okunabilir
      allow read: if resource.data.isActive == true
        || isAdmin()
        || (isBusiness() && resource.data.businessId == request.auth.uid);

      allow write: if isAdmin();
    }

    // ─── homepage_sections ───────────────────────────────────────────────────
    match /homepage_sections/{sectionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── orders ──────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Kullanıcı kendi siparişlerini okuyabilir
      allow read: if isOwner(resource.data.userId) || isAdmin();

      // Sipariş oluşturma Cloud Function üzerinden yapılır,
      // client doğrudan yazamaz
      allow create, update, delete: if isAdmin();
    }

    // ─── coupons ─────────────────────────────────────────────────────────────
    match /coupons/{couponId} {
      // Kullanıcı kendi kuponunu okuyabilir
      allow read: if isOwner(resource.data.userId)
        || isAdmin()
        || (isBusiness() && resource.data.businessId == request.auth.uid);

      // Kupon oluşturma / güncelleme yalnızca Cloud Functions (Admin SDK)
      allow create, update, delete: if false;
    }

    // ─── applications ────────────────────────────────────────────────────────
    match /applications/{applicationId} {
      // Herkes başvuru oluşturabilir (işletme başvuru formu)
      allow create: if request.resource.data.keys().hasAll([
        'businessName', 'campaignTitle', 'description',
        'contactEmail', 'contactPhone'
      ]);

      // Yalnızca admin okuyabilir / güncelleyebilir
      allow read, update, delete: if isAdmin();
    }
  }
}
