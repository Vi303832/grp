rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Yardımcı fonksiyonlar ───────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function hasRole(role) {
      return isAuth() && request.auth.token.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isBusiness() {
      return hasRole('business') || isAdmin();
    }

    // ─── users ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Kullanıcı kendi profilini okuyabilir, admin herkesi okuyabilir
      allow read: if isOwner(userId) || isAdmin();

      // Admin panelinde kullanıcı listeleme için "list" izni
      allow list: if isAdmin();

      // Yeni profil yalnızca kayıt sırasında oluşturulabilir (kendi uid'i ile)
      allow create: if isOwner(userId)
        && request.resource.data.role == 'user'
        && request.resource.data.email == request.auth.token.email;

      // Hassas alanlar (role, email) güncellenemez; geri kalanı güncellenebilir
      // Admin tüm alanları güncelleyebilir (setUserRole fonksiyonu için).
      allow update: if isAdmin()
        || (
          isOwner(userId)
          && !('role' in request.resource.data.diff(resource.data).affectedKeys())
          && !('email' in request.resource.data.diff(resource.data).affectedKeys())
        );

      allow delete: if false;
    }

    // ─── cities ──────────────────────────────────────────────────────────────
    match /cities/{cityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── categories ──────────────────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── businesses ──────────────────────────────────────────────────────────
    match /businesses/{businessId} {
      allow read: if true;

      // İşletme sahibi kendi belgesini güncelleyebilir
      allow update: if isAdmin()
        || (
          isBusiness()
          && resource.data.ownerId == request.auth.uid
          && !('ownerId' in request.resource.data.diff(resource.data).affectedKeys())
          && !('isActive' in request.resource.data.diff(resource.data).affectedKeys())
        );

      allow create, delete: if isAdmin();
    }

    // ─── campaigns ───────────────────────────────────────────────────────────
    match /campaigns/{campaignId} {
      // Aktif kampanyalar herkese, pasifler yalnızca yetkilere açık
      allow get: if (resource.data.isActive == true)
        || isAdmin()
        || (isBusiness() && resource.data.businessId == request.auth.uid);

      // Liste: aktif kampanyaları herkes listeleyebilir;
      // admin her şeyi, işletme kendi kampanyalarını listeleyebilir
      allow list: if true;

      allow write: if isAdmin();
    }

    // ─── homepage_sections ───────────────────────────────────────────────────
    match /homepage_sections/{sectionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── orders ──────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isAdmin();

      // Sipariş oluşturma/güncelleme Cloud Function üzerinden (Admin SDK).
      // Admin panelinden manuel durum güncellemesi için admin create/update açık.
      allow create, update, delete: if isAdmin();
    }

    // ─── coupons ─────────────────────────────────────────────────────────────
    match /coupons/{couponId} {
      allow get: if isOwner(resource.data.userId)
        || isAdmin()
        || (isBusiness() && resource.data.businessId == request.auth.uid);

      allow list: if isAdmin()
        || (isAuth() && request.query.limit <= 50);

      // Yazma yalnızca Cloud Functions (Admin SDK) üzerinden.
      // Admin manuel iptal `cancelCoupon` Cloud Function ile yapılır.
      allow create, update, delete: if false;
    }

    // ─── applications ────────────────────────────────────────────────────────
    match /applications/{applicationId} {
      // Herkes başvuru oluşturabilir (işletme başvuru formu)
      allow create: if request.resource.data.keys().hasAll([
        'businessName', 'campaignTitle', 'description',
        'contactEmail', 'contactPhone'
      ]);

      // Yalnızca admin okuyabilir / güncelleyebilir
      allow read, update, delete: if isAdmin();
    }
  }
}
